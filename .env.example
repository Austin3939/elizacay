# Copy this file to .env and fill in your values.
# Restart the dev server after editing.

# Your Shopify store domain (no https://)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (public — safe to expose in client JS)
# Shopify Admin → Settings → Apps → Develop apps → Create app
# → Storefront API tab → enable scopes → Install → copy token
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
